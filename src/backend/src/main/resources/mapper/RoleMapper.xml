<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sjcw.mapper.RoleMapper">

    <resultMap id="RoleResult" type="com.sjcw.entity.Role">
        <id property="roleId" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleCode" column="role_code"/>
        <result property="description" column="description"/>
        <result property="isEnabled" column="is_enabled"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <sql id="selectRoleVo">
        SELECT role_id, role_name, role_code, description, is_enabled, sort_order,
               created_time, updated_time
        FROM sys_role
    </sql>

    <select id="selectRoleList" parameterType="com.sjcw.entity.Role" resultMap="RoleResult">
        <include refid="selectRoleVo"/>
        <where>
            <if test="roleName != null and roleName != ''">AND role_name LIKE CONCAT('%', #{roleName}, '%')</if>
            <if test="roleCode != null and roleCode != ''">AND role_code LIKE CONCAT('%', #{roleCode}, '%')</if>
            <if test="isEnabled != null">AND is_enabled = #{isEnabled}</if>
        </where>
        ORDER BY sort_order
    </select>
</mapper>
